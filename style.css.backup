:root {
  --primary: #ff7b00;
  --secondary: #00e5ff;
  --glass: rgba(255,255,255,0.08);
  --border: rgba(255,255,255,0.15);
  --text-primary: #ffffff;
  --text-secondary: #e0e0e0;
  --shadow: 0 8px 32px rgba(31, 38, 135, 0.37);
  --gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: 'Poppins', sans-serif;
  background: #0a0a0a;
  color: var(--text-primary);
  overflow-x: hidden;
  line-height: 1.6;
}

.bg-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  z-index: -2;
  overflow: hidden;
}

.moving-bg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  animation: parallax 100s linear infinite;
}

@keyframes parallax {
  0% { transform: translateX(0); }
  50% { transform: translateX(-25%); }
  100% { transform: translateX(0); }
}

/* NAVBAR */
.navbar {
  position: fixed;
  top: 0;
  width: 100%;
  padding: 1rem 5%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(0,0,0,0.9);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  z-index: 1000;
  transition: all 0.3s ease;
}

.logo-space {
  font-size: 1.8rem;
  font-weight: 700;
  background: linear-gradient(45deg, var(--primary), var(--secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  cursor: pointer;
}

.dot {
  color: #ff4757;
  font-size: 1.8rem;
  font-weight: 700;
}

.hamburger {
  display: none;
  flex-direction: column;
  background: none;
  border: none;
  cursor: pointer;
  padding: 5px;
}

.line {
  width: 25px;
  height: 3px;
  background: var(--text-primary);
  margin: 3px 0;
  transition: 0.3s;
}

.nav-links {
  display: flex;
  list-style: none;
  gap: 2rem;
}

.nav-links a {
  color: var(--text-secondary);
  text-decoration: none;
  font-weight: 500;
  transition: all 0.3s ease;
  position: relative;
}

.nav-links a:hover {
  color: var(--primary);
}

.nav-links a::after {
  content: '';
  position: absolute;
  width: 0;
  height: 2px;
  bottom: -5px;
  left: 0;
  background: var(--primary);
  transition: width 0.3s ease;
}

.nav-links a:hover::after {
  width: 100%;
}

/* MAIN CONTENT */
#main-content {
  min-height: 100vh;
  position: relative;
  z-index: 1;
}

.content-section {
  display: none;
  min-height: 100vh;
  padding: 100px 5% 50px;
  opacity: 0;
  transform: translateY(30px);
  transition: all 0.6s ease;
}

.content-section.active {
  display: block;
  opacity: 1;
  transform: translateY(0);
}

.content-section.reveal {
  opacity: 1;
  transform: translateY(0);
}

/* GLASS BOX */
.glass-box {
  background: var(--glass);
  backdrop-filter: blur(20px);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 3rem;
  box-shadow: var(--shadow);
  position: relative;
  overflow: hidden;
}

.glass-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: var(--gradient);
}

.sec-title {
  font-size: clamp(2rem, 5vw, 3.5rem);
  text-align: center;
  margin-bottom: 3rem;
  background: linear-gradient(45deg, var(--primary), var(--secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* HERO SECTION */
.hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  max-width: 1200px;
  margin: 0 auto;
}

.profile-wrapper {
  display: flex;
  justify-content: center;
}

.floating-img {
  width: 300px;
  height: 300px;
  border-radius: 50%;
  object-fit: cover;
  border: 5px solid var(--border);
  box-shadow: var(--shadow);
  animation: float 6s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-20px); }
}

.text-side h1 {
  font-size: clamp(3rem, 8vw, 5rem);
  margin-bottom: 1rem;
  line-height: 1.1;
}

.highlight {
  background: linear-gradient(45deg, var(--primary), var(--secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.typewriter {
  overflow: hidden;
  white-space: nowrap;
  border-right: 3px solid var(--primary);
  animation: typing 3s steps(20, end) forwards, blink 0.75s infinite;
}

@keyframes typing {
  from { width: 0; }
  to { width: 100%; }
}

@keyframes blink {
  0%, 50% { border-color: transparent; }
  51%, 100% { border-color: var(--primary); }
}

.text-side p {
  font-size: 1.3rem;
  margin-bottom: 2rem;
  color: var(--text-secondary);
  max-width: 500px;
}

.btn-main {
  background: var(--gradient);
  color: white;
  border: none;
  padding: 1rem 2.5rem;
  font-size: 1.1rem;
  font-weight: 600;
  border-radius: 50px;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: var(--shadow);
}

.btn-main:hover {
  transform: translateY(-3px);
  box-shadow: 0 15px 40px rgba(102, 126, 234, 0.4);
}

/* ABOUT SECTION */
.about-photo {
  width: 250px;
  height: 250px;
  border-radius: 20px;
  object-fit: cover;
  float: right;
  margin: 0 0 2rem 2rem;
  box-shadow: var(--shadow);
}

.grid-about {
  display: grid;
  gap: 2rem;
  max-width: 1200px;
  margin: 0 auto;
}

.info-card {
  background: var(--glass);
  padding: 2rem;
  border-radius: 15px;
  border: 1px solid var(--border);
  transition: all 0.3s ease;
}

.info-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow);
}

.colorchange {
  background: linear-gradient(45deg, var(--primary), var(--secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* TIMELINE SECTION */
.timeline-section {
  background: radial-gradient(ellipse at center, rgba(20,20,40,0.8) 0%, transparent 70%);
  padding: 100px 5%;
}

.timeline-wrapper {
  max-width: 1000px;
  margin: 0 auto;
}

.section-heading {
  font-size: 3rem;
  text-align: center;
  margin-bottom: 1rem;
  background: linear-gradient(45deg, var(--primary), var(--secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.section-subtitle {
  text-align: center;
  color: var(--text-secondary);
  font-size: 1.2rem;
  margin-bottom: 4rem;
}

.timeline-container {
  position: relative;
  margin: 4rem 0;
}

.timeline-container::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 3px;
  background: linear-gradient(to bottom, var(--primary), var(--secondary));
  transform: translateX(-50%);
}

.timeline-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 4rem;
  position: relative;
}

.timeline-item:nth-child(even) {
  flex-direction: row-reverse;
}

.timeline-marker {
  width: 20px;
  height: 20px;
  background: var(--gradient);
  border-radius: 50%;
  position: absolute;
  left: 50%;
  top: 20px;
  transform: translateX(-50%);
  z-index: 2;
  box-shadow: 0 0 20px rgba(255,123,0,0.5);
}

.timeline-content-box {
  background: var(--glass);
  padding: 2rem;
  border-radius: 15px;
  border: 1px solid var(--border);
  max-width: 45%;
  backdrop-filter: blur(20px);
  box-shadow: var(--shadow);
  transition: all 0.3s ease;
}

.timeline-content-box:hover {
  transform: scale(1.05);
}

.timeline-date {
  color: var(--primary);
  font-weight: 600;
  margin-bottom: 0.5rem;
}

.timeline-title {
  margin-bottom: 1rem;
  color: var(--text-primary);
}

.timeline-description {
  color: var(--text-secondary);
  margin-bottom: 1rem;
}

.timeline-tags {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.tag {
  background: var(--glass);
  padding: 0.3rem 0.8rem;
  border-radius: 20px;
  font-size: 0.85rem;
  border: 1px solid var(--border);
}

.timeline-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 2rem;
  margin-top: 4rem;
  text-align: center;
}

.stat {
  background: var(--glass);
  padding: 2rem 1rem;
  border-radius: 20px;
  border: 1px solid var(--border);
}

.stat-icon {
  font-size: 3rem;
  margin-bottom: 1rem;
}

.stat-value {
  font-size: 2.5rem;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 0.5rem;
}

.stat-label {
  color: var(--text-secondary);
}

/* PROJECTS */
.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
  gap: 2rem;
  max-width: 1400px;
  margin: 3rem auto 0;
}

.project-card {
  background: var(--glass);
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid var(--border);
  transition: all 0.4s ease;
  box-shadow: var(--shadow);
}

.project-card:hover {
  transform: translateY(-10px) scale(1.02);
  box-shadow: 0 25px 50px rgba(0,0,0,0.3);
}

.project-card img {
  width: 100%;
  height: 250px;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.project-card:hover img {
  transform: scale(1.1);
}

.project-content {
  padding: 1.5rem;
}

.cosmic-btn {
  display: inline-block;
  background: var(--gradient);
  color: white;
  padding: 0.8rem 1.5rem;
  text-decoration: none;
  border-radius: 30px;
  font-weight: 500;
  transition: all 0.3s ease;
  margin-top: 1rem;
}

.cosmic-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
}

/* SKILLS */
.skills-wrapper {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2rem;
  max-width: 1200px;
  margin: 3rem auto 0;
}

.skill-card {
  background: var(--glass);
  padding: 2rem;
  border-radius: 20px;
  text-align: center;
  border: 1px solid var(--border);
  transition: all 0.3s ease;
  height: 100%;
}

.skill-card:hover {
  transform: translateY(-10px);
}

.skill-card img {
  width: 80px;
  height: 80px;
  margin-bottom: 1rem;
  filter: brightness(0) invert(1);
}

.progress-container {
  background: rgba(255,255,255,0.1);
  height: 8px;
  border-radius: 4px;
  overflow: hidden;
  margin-top: 1rem;
}

.progress-fill {
  height: 100%;
  background: var(--gradient);
  border-radius: 4px;
  transition: width 2s ease;
}

/* SERVICES */
.services-section {
  background: radial-gradient(circle at top, rgba(255,123,0,0.1) 0%, transparent 70%);
  padding: 100px 5%;
}

.services-wrapper {
  max-width: 1200px;
  margin: 0 auto;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2rem;
  margin-top: 3rem;
}

.service-card {
  background: var(--glass);
  padding: 2.5rem 2rem;
  border-radius: 20px;
  text-align: center;
  border: 1px solid var(--border);
  transition: all 0.3s ease;
  height: 100%;
}

.service-card:hover {
  transform: translateY(-10px);
}

.service-icon {
  font-size: 4rem;
  margin-bottom: 1.5rem;
}

.service-title {
  font-size: 1.5rem;
  margin-bottom: 1rem;
  background: linear-gradient(45deg, var(--primary), var(--secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.service-description {
  color: var(--text-secondary);
  margin-bottom: 1.5rem;
}

.service-list {
  list-style: none;
  text-align: left;
}

.service-list li {
  color: var(--text-secondary);
  margin-bottom: 0.5rem;
  padding-left: 1.5rem;
  position: relative;
}

.check-mark {
  position: absolute;
  left: 0;
  color: #00ff88;
  font-weight: bold;
}

/* CONTACT */
.contact-form {
  max-width: 600px;
  margin: 3rem auto 0;
  background: var(--glass);
